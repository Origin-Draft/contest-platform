PLATFORM_MODE=production
API_PORT=4000
WEB_PORT=4173
POSTGRES_DB=contest_platform
POSTGRES_USER=contest_user
POSTGRES_PASSWORD=change-me
POSTGRES_PORT=5432
DATABASE_URL=postgres://contest_user:change-me@postgres:5432/contest_platform
CONTAINER_DATABASE_URL=postgres://contest_user:change-me@postgres:5432/contest_platform
DATABASE_SSL=false
UPLOAD_DIR=/app/uploads
LOG_LEVEL=info
UPLOAD_MAX_BYTES=52428800
CORS_ALLOWED_ORIGINS=https://app.example.com
AUTH_DEV_BYPASS=false
WEB_ORIGIN=https://app.example.com

# --- Auth provider: keycloak | supabase ---
AUTH_PROVIDER=keycloak

# --- Storage provider: local | supabase ---
STORAGE_PROVIDER=local

# --- Keycloak (used when AUTH_PROVIDER=keycloak) ---
KEYCLOAK_PORT=8080
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=change-me
KEYCLOAK_REALM=contest-platform
KEYCLOAK_DISPLAY_NAME=Origin Draft
KEYCLOAK_LOGIN_THEME=origin-draft
KEYCLOAK_CLIENT_ID=contest-platform-web
KEYCLOAK_CLIENT_NAME=Origin Draft Web
KEYCLOAK_CLIENT_PUBLIC=true
KEYCLOAK_CLIENT_SECRET=replace-with-real-secret
KEYCLOAK_ISSUER_URL=https://auth.example.com/realms/contest-platform
KEYCLOAK_REDIRECT_URIS_JSON=["https://app.example.com/*"]
KEYCLOAK_WEB_ORIGINS_JSON=["https://app.example.com"]
KEYCLOAK_HOSTNAME=https://auth.example.com
KEYCLOAK_HTTP_ENABLED=true
KEYCLOAK_HOSTNAME_STRICT=true
KEYCLOAK_PROXY_HEADERS=xforwarded
KEYCLOAK_SSL_REQUIRED=external
KEYCLOAK_DB_NAME=keycloak
KEYCLOAK_DB_USER=keycloak
KEYCLOAK_DB_PASSWORD=change-me

# --- Supabase (used when AUTH_PROVIDER=supabase or STORAGE_PROVIDER=supabase) ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=replace-with-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=replace-with-supabase-service-role-key
SUPABASE_JWT_SECRET=replace-with-supabase-jwt-secret

# --- Frontend ---
VITE_PLATFORM_MODE=production
VITE_API_BASE_URL=https://api.example.com/api

# --- Docker Compose (self-hosted only) ---
CLOUDFLARE_TUNNEL_TOKEN=replace-with-cloudflare-tunnel-token
