# Copy one of .env.demo.example, .env.dev.example, or .env.production.example to .env for a named setup.
PLATFORM_MODE=development
API_PORT=4000
WEB_PORT=5173
POSTGRES_DB=contest_platform
POSTGRES_USER=contest_user
POSTGRES_PASSWORD=change-me
POSTGRES_PORT=5432
DATABASE_URL=postgres://contest_user:change-me@localhost:5432/contest_platform
CONTAINER_DATABASE_URL=postgres://contest_user:change-me@postgres:5432/contest_platform
UPLOAD_DIR=infra/uploads
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173
AUTH_DEV_BYPASS=false
WEB_ORIGIN=http://localhost:5173
AUTH_PROVIDER=keycloak
STORAGE_PROVIDER=local
KEYCLOAK_PORT=8080
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=change-me
KEYCLOAK_REALM=contest-platform
KEYCLOAK_DISPLAY_NAME=Origin Draft
KEYCLOAK_LOGIN_THEME=origin-draft
KEYCLOAK_CLIENT_ID=contest-platform-web
KEYCLOAK_CLIENT_NAME=contest-platform-web
KEYCLOAK_CLIENT_PUBLIC=true
KEYCLOAK_CLIENT_SECRET=replace-with-real-secret
KEYCLOAK_ISSUER_URL=http://localhost:8080/realms/contest-platform
KEYCLOAK_WEB_ORIGIN=http://localhost:5173
KEYCLOAK_REDIRECT_URIS_JSON=["http://localhost:5173/*","http://localhost:4173/*"]
KEYCLOAK_WEB_ORIGINS_JSON=["http://localhost:5173","http://localhost:4173"]
KEYCLOAK_HOSTNAME=http://localhost:8080
KEYCLOAK_HTTP_ENABLED=true
KEYCLOAK_HOSTNAME_STRICT=false
KEYCLOAK_PROXY_HEADERS=xforwarded
KEYCLOAK_SSL_REQUIRED=none
KEYCLOAK_DB_NAME=keycloak
KEYCLOAK_DB_USER=keycloak
KEYCLOAK_DB_PASSWORD=change-me
VITE_PLATFORM_MODE=development
VITE_API_BASE_URL=http://localhost:4000/api
CLOUDFLARE_TUNNEL_TOKEN=replace-with-cloudflare-tunnel-token
